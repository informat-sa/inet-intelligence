# ============================================================
#  I-NET Intelligence — API (NestJS)
#  Copia este archivo como `.env` y completa los valores reales
# ============================================================

# ----------------------------
# MODO DEMO (sin credenciales)
# ----------------------------
# true  → respuestas pre-fabricadas, NO llama a Claude ni a SQL Server
# false → modo producción, requiere ANTHROPIC_API_KEY y credenciales SQL
DEMO_MODE=true

# ----------------------------
# ANTHROPIC / CLAUDE API
# ----------------------------
# Obtén tu key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelos Claude (opcionales — si no se configuran se usan los valores por defecto)
# Actualizar aquí cuando Anthropic lance nuevas versiones sin necesidad de redeployar código.
# Verificar nombres válidos en: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_SMART=claude-sonnet-4-5

# ----------------------------
# SQL SERVER — INET ERP (Informat)
# ----------------------------
# Servidor: nombre Windows o IP con instancia (ej: centauro o 192.168.1.10\SQLEXPRESS)
DB_SERVER=centauro
# Base de datos principal de INET
DB_DATABASE=INET_STD
# Usuario SQL Server con permisos SELECT en las tablas de INET
DB_USER=inet_readonly
# Contraseña del usuario SQL Server
DB_PASSWORD=TU_PASSWORD_AQUI
# Puerto (1433 por defecto)
DB_PORT=1433
# Cifrado de conexión: false para redes locales, true para Azure SQL
DB_ENCRYPT=false

# ----------------------------
# CORS / URL DEL FRONTEND
# ----------------------------
# URL donde corre el frontend (Next.js)
# Desarrollo: http://localhost:3000
# Producción: https://tu-app.vercel.app
WEB_URL=http://localhost:3000

# ----------------------------
# KB / SCHEMA (GeneXus Knowledge Base)
# ----------------------------
# Ruta a la carpeta que contiene _full_attributes.json y _language_objects.json
# En Railway/Docker, copiar los archivos al contenedor y apuntar aquí.
# Desarrollo: dejar vacío (usa ruta relativa al proyecto automáticamente)
KB_DOCS_PATH=/app/docs

# ----------------------------
# CIFRADO DE CONTRASEÑAS (multi-tenant)
# ----------------------------
# Clave AES-256-GCM para cifrar contraseñas de SQL Server en PostgreSQL.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRÍTICO: sin esta variable en producción el sistema rechazará iniciar.
DB_ENCRYPTION_KEY=genera-una-clave-de-64-caracteres-hex-aqui

# ----------------------------
# POSTGRESQL (multi-tenant — requerido en producción)
# ----------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=inet_intelligence
PG_USER=postgres
PG_PASSWORD=TU_PASSWORD_PG
PG_SSL=false

# ----------------------------
# JWT
# ----------------------------
JWT_SECRET=genera-un-secret-de-al-menos-64-caracteres-aqui
JWT_EXPIRES_IN=8h

# ----------------------------
# EMAIL (para invitaciones de usuarios)
# ----------------------------
MAIL_HOST=smtp.informat.cl
MAIL_PORT=587
MAIL_USER=noreply@informat.cl
MAIL_PASSWORD=TU_PASSWORD_SMTP
MAIL_FROM="I-NET Intelligence <noreply@informat.cl>"
PORTAL_URL=https://tu-app.vercel.app

# ----------------------------
# NOTAS PARA EL EQUIPO
# ----------------------------
# 1. El usuario DB (DB_USER) debe tener SOLO permisos SELECT en SQL Server (seguridad)
# 2. DEMO_MODE=true: no requiere PG, SQL Server ni API key. Para demos y onboarding.
# 3. DEMO_MODE=false + PG_HOST vacío = ERROR en login (no permite backdoor anónimo)
# 4. En producción SIEMPRE configurar: DB_ENCRYPTION_KEY, JWT_SECRET, PG_HOST, ANTHROPIC_API_KEY
