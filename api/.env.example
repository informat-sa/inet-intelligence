# ============================================================
#  I-NET Intelligence — API (NestJS)
#  Copia este archivo como `.env` y completa los valores reales
# ============================================================

# ----------------------------
# MODO DEMO (sin credenciales)
# ----------------------------
# true  → respuestas pre-fabricadas, NO llama a Claude ni a SQL Server
# false → modo producción, requiere ANTHROPIC_API_KEY y credenciales SQL
DEMO_MODE=true

# ----------------------------
# ANTHROPIC / CLAUDE API
# ----------------------------
# Obtén tu key en: https://console.anthropic.com/settings/keys
# Modelo usado: claude-3-5-sonnet-20241022  (configurable en query.service.ts)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------
# SQL SERVER — INET ERP (Informat)
# ----------------------------
# Servidor: nombre Windows o IP con instancia (ej: centauro o 192.168.1.10\SQLEXPRESS)
DB_SERVER=centauro
# Base de datos principal de INET
DB_DATABASE=INET_STD
# Usuario SQL Server con permisos SELECT en las tablas de INET
DB_USER=inet_readonly
# Contraseña del usuario SQL Server
DB_PASSWORD=TU_PASSWORD_AQUI
# Puerto (1433 por defecto)
DB_PORT=1433
# Cifrado de conexión: false para redes locales, true para Azure SQL
DB_ENCRYPT=false

# ----------------------------
# CORS / URL DEL FRONTEND
# ----------------------------
# URL donde corre el frontend (Next.js)
# Desarrollo: http://localhost:3000
# Producción: https://tu-app.vercel.app
WEB_URL=http://localhost:3000

# ----------------------------
# SCHEMA (opcional)
# ----------------------------
# Ruta al archivo JSON con el esquema de tablas INET exportado
# Si no se provee, se usa api/src/schema/schema.json (si existe)
# SCHEMA_PATH=/ruta/a/tu/schema.json

# ----------------------------
# NOTAS PARA EL EQUIPO
# ----------------------------
# 1. El usuario DB debe tener SOLO permisos SELECT (seguridad)
# 2. El schema JSON se genera desde INET con el exportador incluido
#    (ver documentación en README.md, sección "Exportar Schema")
# 3. Con DEMO_MODE=true el sistema funciona completamente sin SQL Server
#    ni API key — ideal para demos y presentaciones
