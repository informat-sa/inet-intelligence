# ============================================================
#  I-NET Intelligence — Web (Next.js)
#  Copia este archivo como `.env.local` y completa los valores
# ============================================================

# ----------------------------
# URL DE LA API (NestJS)
# ----------------------------
# IMPORTANTE: Esta variable es SERVER-SIDE ONLY (sin prefijo NEXT_PUBLIC_)
# El browser nunca llama directamente a la API — pasa por rutas proxy de Next.js
#
# Desarrollo local:
API_URL=http://localhost:3001
#
# Producción (Railway u otro host):
# API_URL=https://tu-api.up.railway.app

# ----------------------------
# NOMBRE DE LA APLICACIÓN
# ----------------------------
# Se muestra en el título de la página y el sidebar
NEXT_PUBLIC_APP_NAME=I-NET Intelligence

# ----------------------------
# NOTAS PARA EL EQUIPO
# ----------------------------
# 1. NUNCA uses NEXT_PUBLIC_API_URL — expondría la URL interna al browser
# 2. Las rutas proxy están en:
#      web/app/api/query/stream/route.ts   → POST /query/stream
#      web/app/api/auth/login/route.ts     → POST /auth/login
#      web/app/api/health/route.ts         → GET  /health
# 3. En Vercel, agrega API_URL como variable de entorno en el dashboard
#    apuntando a la URL de Railway donde corre la API
